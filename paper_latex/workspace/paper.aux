\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Distribution of feed-forward loop (030T) Z-scores across 8 capability domains (200 graphs total). Each box shows the interquartile range with median line; whiskers extend to 1.5$\times $ IQR. Dashed horizontal lines indicate FFL Z-scores from canonical biological networks\nobreakspace  {}\citep  {Milo2002}. All 200 graphs show positive Z-scores, and all domain medians exceed biological benchmarks by 3.7--5.5$\times $.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:ffl_zscores}{{2}{7}{Distribution of feed-forward loop (030T) Z-scores across 8 capability domains (200 graphs total). Each box shows the interquartile range with median line; whiskers extend to 1.5$\times $ IQR. Dashed horizontal lines indicate FFL Z-scores from canonical biological networks~\citep {Milo2002}. All 200 graphs show positive Z-scores, and all domain medians exceed biological benchmarks by 3.7--5.5$\times $}{figure.2}{}}
